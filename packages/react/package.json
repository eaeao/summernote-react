{
  "name": "@summernote/react",
  "version": "0.0.0",
  "description": "React bindings for @summernote/core (controlled <SummernoteEditor> + useSummernote hook)",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./src/styles/summernote-lite.css",
    "./themes/bs3.css": "./src/styles/themes/bs3.css",
    "./themes/bs4.css": "./src/styles/themes/bs4.css",
    "./themes/bs5.css": "./src/styles/themes/bs5.css"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@summernote/core": "*"
  }
}
