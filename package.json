{
  "name": "@eaeao/summernote-react",
  "version": "1.0.1",
  "description": "React + TypeScript port of summernote — editor engine + React bindings in one package (zero runtime deps, no jQuery, no execCommand)",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./src/styles/summernote-lite.css",
    "./icons.css": "./src/styles/summernote-icons.css",
    "./themes/bs3.css": "./src/styles/themes/bs3.css",
    "./themes/bs4.css": "./src/styles/themes/bs4.css",
    "./themes/bs5.css": "./src/styles/themes/bs5.css"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:no-jquery": "node scripts/check-no-jquery.mjs",
    "check:deps": "node scripts/check-no-runtime-deps.mjs",
    "verify": "yarn lint:no-jquery && yarn check:deps && yarn typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "yarn verify && yarn build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/browser": "^3.0.0",
    "playwright": "^1.48.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vitest": "^3.0.0"
  }
}
